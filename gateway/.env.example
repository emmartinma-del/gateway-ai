# x402 Gateway Configuration

# Port to run the gateway server on
PORT=3001

# EVM private key for the gateway wallet (hex, with or without 0x prefix)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Fund this address with testnet ETH and USDC on Base Sepolia:
# - ETH: https://www.alchemy.com/faucets/base-sepolia
# - USDC: https://faucet.circle.com/
WALLET_PRIVATE_KEY=0xyour_private_key_here

# Network: "base-sepolia" for testnet, "base" for mainnet (DO NOT use mainnet without CEO approval)
NETWORK=base-sepolia

# Gateway fee: 0.15% taken on each transaction
GATEWAY_FEE_BPS=15

# SQLite database path
DATABASE_PATH=./data/gateway.db

# Optional: Admin dashboard password (leave blank to disable auth)
ADMIN_PASSWORD=
