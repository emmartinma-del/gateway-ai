# x402 Gateway Configuration

# ============================================================
# SECRETS — NEVER commit real values. In production, inject
# these via your platform's secrets manager (Docker secrets,
# Kubernetes secrets, AWS Secrets Manager, etc.) and set
# NODE_ENV=production so .env is NOT loaded automatically.
# ============================================================

# EVM private key for the gateway signing wallet (hex, with or without 0x prefix)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Fund with testnet ETH + USDC on Base Sepolia:
#   ETH:  https://www.alchemy.com/faucets/base-sepolia
#   USDC: https://faucet.circle.com/
WALLET_PRIVATE_KEY=0xyour_private_key_here

# ============================================================
# NETWORK & SERVER
# ============================================================

# Port to run the gateway server on
PORT=3001

# Network: "base-sepolia" (testnet, safe default) or "base" (mainnet — CEO approval required)
# All 5 mainnet readiness criteria must be met before switching to "base".
NETWORK=base-sepolia

# SQLite database path
DATABASE_PATH=./data/gateway.db

# ============================================================
# FEES
# ============================================================

# Gateway fee in basis points (0.15% = 15 bps)
GATEWAY_FEE_BPS=15

# Company wallet address to receive gateway fees (required for mainnet)
# This is the address where accumulated gateway fees should be swept.
# Leave blank on testnet; REQUIRED before mainnet go-live.
FEE_RECIPIENT_ADDRESS=

# ============================================================
# SPENDING LIMITS (required for mainnet)
# Amounts in USDC atomic units (6 decimals): $1 = 1000000
# Set to 0 to disable (not recommended for mainnet)
# ============================================================

# Maximum payment amount per single request
# Example: 10000000 = $10 USDC per request
MAX_PAYMENT_PER_REQUEST=0

# Maximum total spend per UTC calendar day
# Example: 1000000000 = $1000 USDC per day
MAX_DAILY_SPEND=0

# ============================================================
# ENDPOINT ALLOWLIST (required for mainnet)
# Comma-separated list of hostnames the gateway may proxy to.
# Empty = allow all (development only — not safe for production)
# Example: api.example.com,service.io
# ============================================================
ALLOWED_DOMAINS=

# ============================================================
# AUTHENTICATION (required for mainnet)
# Comma-separated bearer tokens clients must send in the Authorization header.
# Empty = no auth (development only — not safe for production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
API_KEYS=

# ============================================================
# ADMIN
# ============================================================

# Optional: Admin dashboard password (leave blank to disable auth)
ADMIN_PASSWORD=
